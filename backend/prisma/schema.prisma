generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  displayName   String?
  phone         String?
  bio           String?
  timezone      String    @default("UTC+5:30")
  country       String?
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  emailVerified Boolean   @default(false)
  verifyCode    String?
  verifyExpiry  DateTime?
  // ── Password reset (Approach C: OTP + short-lived reset token) ──
  resetOtp         String?
  resetOtpExpiry   DateTime?
  resetOtpAttempts Int       @default(0) // wrong-OTP counter; reset on new OTP request
  resetTokenHash   String? // sha256 of JWT resetToken — single-use check
  resetTokenExpiry DateTime?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  brokers            Broker[]
  deployedStrategies DeployedStrategy[]
  refreshTokens      RefreshToken[]
  backtestRuns       BacktestRun[]
  notifications      Notification[]
  subscriptions      Subscription[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Broker {
  id          String       @id @default(uuid())
  userId      String
  uid         String       @default("") // user-given label to identify broker
  exchangeId  String // ccxt exchange id: "delta", "binance", etc.
  name        String // exchange display name
  apiKey      String // encrypted
  apiSecret   String // encrypted
  passphrase  String? // encrypted, optional
  status      BrokerStatus @default(CONNECTED)
  ipWhitelist Boolean      @default(false)
  connectedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployedStrategies DeployedStrategy[]

  @@unique([userId, exchangeId, apiKey])
  @@index([userId])
  @@index([userId, status])
  @@map("brokers")
}

model Strategy {
  id          String    @id @default(uuid())
  name        String
  description String
  category    String // Grid, DCA, Trend, Mean Reversion, Arbitrage, Scalping
  riskLevel   RiskLevel
  config      Json // strategy-specific parameters
  isSystem    Boolean   @default(true) // system = pre-built template
  isVisible   Boolean   @default(true) // false = hidden from strategy page but retained for existing deployments
  // Per-trade position sizing (% of invested capital deployed per entry)
  defaultPositionSize Float   @default(10)    // percent, e.g. 10 = 10%
  positionSizeLocked  Boolean @default(false) // if true, user cannot override in deploy dialog
  // Live-sync tracking — tracks whether this local row has been pushed to prod DB
  liveSyncStatus String? // "synced" | "error" | "pushing" | null (never pushed)
  liveSyncAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deployedStrategies DeployedStrategy[]
  featuredBacktests  BacktestRun[]      @relation("FeaturedBacktests")

  @@map("strategies")
}

model DeployedStrategy {
  id             String         @id @default(uuid())
  userId         String
  strategyId     String
  brokerId       String
  pair           String // e.g. "BTC/USDT"
  status         DeployedStatus @default(ACTIVE)
  investedAmount Float
  currentValue   Float          @default(0)
  config         Json // user overrides: stop loss, take profit, etc.
  deployedAt     DateTime       @default(now())
  stoppedAt      DateTime?
  updatedAt      DateTime       @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id])
  broker   Broker   @relation(fields: [brokerId], references: [id])
  trades   Trade[]

  @@index([userId, status])
  @@index([userId, deployedAt])
  @@index([brokerId])
  @@index([strategyId])
  @@index([status])
  @@map("deployed_strategies")
}

model Trade {
  id                 String      @id @default(uuid())
  deployedStrategyId String
  pair               String
  side               Side
  entryPrice         Float
  exitPrice          Float?
  quantity           Float
  pnl                Float       @default(0)
  fee                Float       @default(0)
  status             TradeStatus @default(OPEN)
  exchangeOrderId    String? // order id from exchange
  openedAt           DateTime    @default(now())
  closedAt           DateTime?

  deployedStrategy DeployedStrategy @relation(fields: [deployedStrategyId], references: [id], onDelete: Cascade)

  @@index([deployedStrategyId, status])
  @@index([deployedStrategyId, openedAt])
  @@map("trades")
}

enum Plan {
  FREE
  PRO
  MAX
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id          String             @id @default(uuid())
  userId      String
  plan        Plan
  cycle       BillingCycle
  status      SubscriptionStatus @default(ACTIVE)
  amount      Float // price paid
  startDate   DateTime           @default(now())
  endDate     DateTime // when billing period ends
  cancelledAt DateTime?
  createdAt   DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("subscriptions")
}

enum BrokerStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum DeployedStatus {
  ACTIVE
  PAUSED
  STOPPED
  DELETED
}

enum Side {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
}

// ── Backtest Models ─────────────────────────────────────────

model BacktestRun {
  id              String   @id @default(uuid())
  userId          String
  coin            String
  startDate       DateTime
  endDate         DateTime
  strategyType    String // "code" or "ui"
  strategyName    String
  strategyConfig  Json
  initialCapital  Float
  finalEquity     Float    @default(0)
  totalPnl        Float    @default(0)
  grossPnl        Float    @default(0)
  totalFees       Float    @default(0)
  makerFee        Float    @default(0.0005)
  slippage        Float    @default(0.0001)
  totalTrades     Int      @default(0)
  winTrades       Int      @default(0)
  lossTrades      Int      @default(0)
  winRate         Float    @default(0)
  maxDrawdown     Float    @default(0)
  sharpeRatio     Float    @default(0)
  profitFactor    Float    @default(0)
  avgWin          Float    @default(0)
  avgLoss         Float    @default(0)
  bestTrade       Float    @default(0)
  worstTrade      Float    @default(0)
  equityCurve     Json     @default("[]")
  extendedMetrics Json? // drawdownCurve, cumulativePnlCurve, largestWin/LossTrades, avgBars, mddRecoveryDays
  status          String   @default("RUNNING") // RUNNING, COMPLETED, FAILED
  duration        Int? // ms to complete
  createdAt       DateTime @default(now())

  // Featured backtest — shown publicly on strategy detail page
  isFeatured         Boolean @default(false)
  periodLabel        String? // "1Y", "2Y", "3Y"
  featuredStrategyId String?

  // Live-sync tracking — does this run also exist on prod DB?
  liveSyncStatus     String? // "synced" | "error" | "pushing" | null
  liveSyncAt         DateTime?

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades           BacktestTrade[]
  featuredStrategy Strategy?       @relation("FeaturedBacktests", fields: [featuredStrategyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([isFeatured, featuredStrategyId, coin, periodLabel])
  @@map("backtest_runs")
}

model BacktestTrade {
  id            String    @id @default(uuid())
  backtestRunId String
  entryTime     DateTime
  entryPrice    Float
  qty           Float
  side          String // "BUY" or "SELL"
  leverage      Float     @default(1)
  sl            Float?
  tp            Float?
  exitTime      DateTime?
  exitPrice     Float?
  pnl           Float     @default(0)
  fee           Float     @default(0)
  exitReason    String? // "TP", "SL", "SIGNAL", "END"
  status        String    @default("OPEN")

  backtestRun BacktestRun @relation(fields: [backtestRunId], references: [id], onDelete: Cascade)

  @@index([backtestRunId])
  @@map("backtest_trades")
}

// ── Notifications ───────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // "trade_open", "trade_close", "strategy_deploy", "strategy_stop"
  title     String
  message   String
  data      Json? // extra context: { pair, pnl, strategyName, ... }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}
